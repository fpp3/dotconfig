smart_borders yes
focus_follows_mouse no
bindsym XF86PowerOff exec --no-startup-id /home/fpp/.config/rofi/scripts/powermenu_t2
#Bind media player buttons
bindsym XF86AudioPlay exec "$HOME/.config/sway/multimedia_handler.sh play-pause"
bindsym XF86AudioStop exec "$HOME/.config/sway/multimedia_handler.sh stop"
bindsym XF86AudioPrev exec "$HOME/.config/sway/multimedia_handler.sh previous"
bindsym XF86AudioNext exec "$HOME/.config/sway/multimedia_handler.sh next"
bindsym XF86AudioRaiseVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ +5%
bindsym XF86AudioLowerVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ -5%
bindsym XF86AudioMute exec --no-startup-id pactl set-sink-mute @DEFAULT_SINK@ toggle
bindsym XF86MonBrightnessUp exec --no-startup-id brightnessctl s +711
bindsym XF86MonBrightnessDown exec --no-startup-id brightnessctl s 711- 

# Screenshots
bindsym $mod+Print exec --no-startup-id sway-screenshot --mode output --output-folder "$HOME/Imágenes/" --filename "$(date +%H%M_%d%m%Y).png"
bindsym $mod+Ctrl+Print exec --no-startup-id sway-screenshot --mode window --output-folder "$HOME/Imágenes/" --filename "$(date +%H%M_%d%m%Y).png"
bindsym $mod+Shift+Print exec --no-startup-id sway-screenshot --mode region --output-folder "$HOME/Imágenes/" --filename "$(date +%H%M_%d%m%Y).png"

## Clipboard Screenshots
bindsym Print exec --no-startup-id sway-screenshot --mode output --clipboard-only
bindsym Ctrl+Print exec --no-startup-id sway-screenshot --mode window --clipboard-only
bindsym Shift+Print exec --no-startup-id sway-screenshot --mode region --clipboard-only

## waybar
exec --no-startup-id waybar

## font
font pango:monospace 9
#exec_always gsettings set org.gnome.desktop.interface text-scaling-factor 0.9

titlebar_border_thickness 2
titlebar_padding 6 2

# screenshare
exec --no-startup-id "$HOME/.config/sway/wayland_display_fix.sh"


